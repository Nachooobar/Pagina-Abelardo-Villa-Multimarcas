<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-layout">
    <%- include('sidebar') %>
    <main class="admin-main">
      <div class="admin-header">
        <h1>📊 Dashboard</h1>
        <span style="color:var(--text-muted); font-size:0.85rem;">Bienvenido, Admin</span>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon blue">🚗</div>
          <div class="stat-number"><%= stats.totalAutos %></div>
          <div class="stat-label">Vehículos Total</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon green">✅</div>
          <div class="stat-number"><%= stats.totalActivos %></div>
          <div class="stat-label">Activos / Publicados</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon gold">⭐</div>
          <div class="stat-number"><%= stats.totalDestacados %></div>
          <div class="stat-label">Destacados</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon purple">📷</div>
          <div class="stat-number"><%= stats.totalImagenes %></div>
          <div class="stat-label">Imágenes Cargadas</div>
        </div>
      </div>

      <div class="admin-table-wrap">
        <div class="admin-table-header">
          <h2>Últimos Vehículos Cargados</h2>
          <a href="/admin/autos/nuevo" class="btn btn-primary btn-sm">+ Agregar Vehículo</a>
        </div>
        <table>
          <thead>
            <tr><th>Imagen</th><th>Vehículo</th><th>Año</th><th>Precio</th><th>Estado</th></tr>
          </thead>
          <tbody>
            <% ultimosAutos.forEach(auto => { %>
            <tr>
              <td><% if(auto.imagen){ %><img src="/uploads/autos/<%= auto.imagen %>" class="table-img"><% } else { %><div class="table-img" style="background:var(--primary-light);display:flex;align-items:center;justify-content:center;font-size:0.7rem;color:var(--text-muted);">—</div><% } %></td>
              <td><strong style="color:var(--white);"><%= auto.marca %> <%= auto.modelo %></strong></td>
              <td><%= auto.anio %></td>
              <td><% if(auto.precio > 0){ %><%= auto.moneda %> <%= auto.precio.toLocaleString('es-AR') %><% } else { %>Consultar<% } %></td>
              <td><span class="badge <%= auto.activo ? 'badge-success' : 'badge-danger' %>"><%= auto.activo ? 'Activo' : 'Inactivo' %></span></td>
            </tr>
            <% }) %>
            <% if(ultimosAutos.length === 0) { %>
            <tr><td colspan="5" style="text-align:center; padding:2rem; color:var(--text-muted);">No hay vehículos cargados aún. <a href="/admin/autos/nuevo" style="color:var(--accent);">Cargar el primero →</a></td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </main>
  </div>
</body>
</html>
