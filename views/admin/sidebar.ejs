<!-- Admin Sidebar -->
<aside class="admin-sidebar" id="adminSidebar">
  <div class="admin-sidebar-brand">
    <img src="/images/logo.png" alt="Logo" style="width:100%;max-width:200px;margin:0 auto 0.5rem;display:block;border-radius:8px;">
  </div>
  <div class="admin-sidebar-sub">Panel de Control</div>
  <nav class="admin-nav">
    <a href="/admin" class="<%= typeof title !== 'undefined' && title.includes('Panel') ? 'active' : '' %>">📊 Dashboard</a>
    <a href="/admin/autos" class="<%= typeof title !== 'undefined' && (title.includes('Gestión') || title.includes('Editar')) ? 'active' : '' %>">🚗 Vehículos</a>
    <a href="/admin/autos/nuevo" class="<%= typeof title !== 'undefined' && title.includes('Agregar') ? 'active' : '' %>">➕ Agregar Auto</a>
    <div class="admin-nav-divider"></div>
    <a href="/admin/config" class="<%= typeof title !== 'undefined' && title.includes('Configuración') ? 'active' : '' %>">⚙️ Configuración</a>
    <a href="/" target="_blank">🌐 Ver Sitio Web</a>
    <div class="admin-nav-divider"></div>
    <a href="/admin/logout" style="color:#EF4444;">🚪 Cerrar Sesión</a>
  </nav>
  <div style="padding:1rem 1.25rem 0.75rem;margin-top:auto;border-top:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;gap:0.4rem;opacity:0.4;transition:opacity 0.3s;" onmouseenter="this.style.opacity='0.8'" onmouseleave="this.style.opacity='0.4'">
    <span style="font-size:0.6rem;color:rgba(255,255,255,0.6);letter-spacing:0.3px;">by</span>
    <img src="/images/astroweb-logo.png" alt="Astro Web" style="height:22px;width:auto;object-fit:contain;filter:brightness(0) invert(1);opacity:0.7;">
  </div>
</aside>
<!-- Mobile menu button -->
<button class="mobile-menu-toggle" id="mobileMenuBtn" onclick="document.getElementById('adminSidebar').classList.toggle('open');document.getElementById('mobileOverlay').classList.toggle('active');">☰</button>
<div class="mobile-overlay" id="mobileOverlay" onclick="document.getElementById('adminSidebar').classList.remove('open');this.classList.remove('active');"></div>
