  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <img src="/images/logo.png" alt="<%= brand.name %>" class="footer-logo">
          <p class="footer-text"><%= brand.bio %></p>
        </div>
        <div>
          <h4>Navegación</h4>
          <div class="footer-links">
            <a href="/">Inicio</a>
            <a href="/catalogo">Catálogo</a>
            <a href="/nosotros">Nosotros</a>
            <a href="/contacto">Contacto</a>
          </div>
        </div>
        <div>
          <h4>Marcas Populares</h4>
          <div class="footer-links">
            <a href="/catalogo?marca=Toyota">Toyota</a>
            <a href="/catalogo?marca=Volkswagen">Volkswagen</a>
            <a href="/catalogo?marca=Ford">Ford</a>
            <a href="/catalogo?marca=Chevrolet">Chevrolet</a>
            <a href="/catalogo?marca=Fiat">Fiat</a>
          </div>
        </div>
        <div>
          <h4>Contacto</h4>
          <div class="footer-links">
            <a href="<%= brand.contact.maps.url %>" target="_blank">📍 <%= brand.contact.maps.address %></a>
            <a href="tel:<%= brand.contact.phone %>">📞 <%= brand.contact.phone %></a>
            <a href="<%= getWhatsAppLink() %>" target="_blank">💬 WhatsApp</a>
            <% if (brand.social.instagram) { %>
              <a href="<%= brand.social.instagram %>" target="_blank">📸 Instagram</a>
            <% } %>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; <%= currentYear %> <%= brand.name %>. Todos los derechos reservados.</p>
        <div style="margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:center;gap:0.6rem;opacity:0.55;transition:opacity 0.3s;" onmouseenter="this.style.opacity='0.9'" onmouseleave="this.style.opacity='0.55'">
          <span style="font-size:0.7rem;color:var(--text-secondary);letter-spacing:0.5px;">Desarrollado por</span>
          <img src="/images/astroweb-logo.png" alt="Astro Web" style="height:28px;width:auto;object-fit:contain;filter:brightness(0) invert(1);opacity:0.85;">
        </div>
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    document.getElementById('mobileToggle').addEventListener('click', () => {
      document.getElementById('navLinks').classList.toggle('active');
    });
    // Navbar scroll effect
    window.addEventListener('scroll', () => {
      document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 50);
    });
    // Fade-in on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => { if (entry.isIntersecting) { entry.target.classList.add('visible'); } });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  </script>
</body>
</html>
