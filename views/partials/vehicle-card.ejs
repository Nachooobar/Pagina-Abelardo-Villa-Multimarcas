<%
  function getImageSrc(auto) {
    if (auto.imagen_principal) return '/uploads/autos/' + auto.imagen_principal;
    if (auto.imagen_fallback) return '/uploads/autos/' + auto.imagen_fallback;
    if (auto.imagen) return '/uploads/autos/' + auto.imagen;
    return null;
  }
  const imgSrc = getImageSrc(auto);
  const slug = generateSlug(auto.marca, auto.modelo);
%>
<a href="/auto/<%= slug %>-<%= auto.id %>" class="vehicle-card fade-in" id="vehicle-<%= auto.id %>">
  <div class="card-image">
    <% if (imgSrc) { %>
      <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" data-src="<%= imgSrc %>" alt="<%= auto.marca %> <%= auto.modelo %>" loading="lazy" class="lazy-img">
    <% } else { %>
      <div class="no-image">📷 Sin imagen</div>
    <% } %>
    <span class="card-badge <%= auto.condicion === 'Usado' ? 'usado' : '' %>"><%= auto.condicion %></span>
  </div>
  <div class="card-body">
    <div class="card-brand"><%= auto.marca %></div>
    <div class="card-title"><%= auto.modelo %> <%= auto.version %></div>
    <div class="card-specs">
      <span class="card-spec">
        <svg viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" fill="none" stroke-width="2"/></svg>
        <%= auto.anio %>
      </span>
      <span class="card-spec">
        <svg viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke="currentColor" fill="none" stroke-width="2"/></svg>
        <%= auto.combustible %>
      </span>
      <% if (auto.kilometraje > 0) { %>
      <span class="card-spec">
        <svg viewBox="0 0 24 24"><path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" stroke="currentColor" fill="none" stroke-width="2"/></svg>
        <%= new Intl.NumberFormat('es-AR').format(auto.kilometraje) %> km
      </span>
      <% } %>
    </div>
    <div class="card-footer">
      <% if (auto.precio > 0) { %>
        <div class="card-price"><span class="currency"><%= auto.moneda === 'ARS' ? '$' : 'U$S' %></span> <%= new Intl.NumberFormat('es-AR').format(auto.precio) %></div>
      <% } else { %>
        <div class="card-price" style="font-size:0.9rem;">Consultar</div>
      <% } %>
      <span class="card-link">Ver más →</span>
    </div>
  </div>
</a>
