<%- include('partials/header') %>
<section class="contact-page">
  <div class="container">
    <div class="section-header fade-in" style="margin-top:1rem;">
      <div class="section-tag">🏢 Nosotros</div>
      <h1 class="section-title">Abelardo Villa Multimarcas</h1>
      <p class="section-subtitle">40 Años de experiencia en el mercado automotor</p>
    </div>
    <div class="contact-grid">
      <div class="fade-in">
        <div class="contact-info-card">
